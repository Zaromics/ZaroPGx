
name: zaropgx
services:
  # ~~~~~~~~~~MAIN APP~~~~~~~~~~
  app:
    # Default: pull the published image. Fallback: `docker compose build` builds locally.
    image: zaromicsresearch/zaropgx-app:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: Dockerfile
    container_name: pgx_app
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
      pharmcat:
        condition: service_healthy
    environment:
      - DATABASE_URL=postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
      - SECRET_KEY=${SECRET_KEY}
      - PHARMCAT_API_URL=http://pharmcat:5000
      - PHARMCAT_JAR_PATH=/pharmcat/pharmcat.jar
      - INCLUDE_PHARMCAT_HTML=true
      - INCLUDE_PHARMCAT_JSON=true
      - INCLUDE_PHARMCAT_TSV=true
      - GATK_API_URL=http://gatk-api:5000
      - PYPGX_API_URL=http://pypgx:5000
      - GENOME_DOWNLOADER_API_URL=http://genome-downloader:5050
      - USE_NEXTFLOW=${USE_NEXTFLOW} # deprecated
      - NEXTFLOW_RUNNER_URL=${NEXTFLOW_RUNNER_URL}
      - FHIR_SERVER_URL=http://fhir-server:8080/fhir
      - KROKI_URL=http://kroki:8000
      - SOURCE_URL=${SOURCE_URL}
      - FHIR_EXPORT_ENABLED=${FHIR_EXPORT_ENABLED:-true}
      - PYTHONPATH=/app
      - WORKFLOW_API_BASE=http://app:8000/api/v1
      - PYTHONDONTWRITEBYTECODE=1
      - LOG_LEVEL=${LOG_LEVEL:-DEBUG}
      - EXECSUM_USE_TSV=true
    volumes:
      - ./:/app
      - ./data:/data
      - ./scripts:/scripts:ro
    ports:
      - "${BIND_ADDRESS:-8765}:8000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    networks:
      - pgx-network
    command: ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
  
  
  # PostgreSQL Database
  db:
    image: postgres:18
    container_name: pgx_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_USER:-zaropgx_user}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-test123}
      POSTGRES_DB: ${DB_NAME:-zaropgx_db}
    volumes:
      # PG18+ stores data in a major-version subdir and rejects a mount at
      # /var/lib/postgresql/data; mount the volume at the postgres home instead.
      - pgdata:/var/lib/postgresql
      - ./db/init:/docker-entrypoint-initdb.d
    ports:
      - "5444:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-zaropgx_user} -d ${DB_NAME:-zaropgx_db}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - pgx-network


  # Reference material downloader service
  genome-downloader:
    image: zaromicsresearch/zaropgx-genome-downloader:${ZAROPGX_TAG:-0.2.7}
    build:
      context: ./docker/genome-downloader
      dockerfile: Dockerfile.downloader
    container_name: pgx_genome_downloader
    volumes:
      - ./reference:/reference
    environment:
      - DOWNLOAD_ON_STARTUP=true
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5050/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 2G
    ports:
      - "5050:5050"
    networks:
      - pgx-network


  # PharmCAT Service Wrapper - combines JAR and API
  pharmcat:
    image: zaromicsresearch/zaropgx-pharmcat:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: docker/pharmcat/Dockerfile
      args:
        PHARMCAT_VERSION: ${PHARMCAT_VERSION:-3.2.0}
    container_name: pgx_pharmcat
    restart: unless-stopped
    volumes:
      - ./data:/data
      # Mount reference files where PharmCAT expects them
      - pharmcat-references:/pharmcat
    ports:
      # FastAPI
      - "5001:5000"
    environment:
      - DATA_DIR=/data
      - JAVA_OPTS=-Xmx4g
      - PHARMCAT_LOG_LEVEL=DEBUG
      - PHARMCAT_REFERENCE_DIR=/pharmcat
      - PHARMCAT_TEE=true
      - PHARMCAT_ABSENT_TO_REF=${PHARMCAT_ABSENT_TO_REF:-false}
      - PHARMCAT_UNSPECIFIED_TO_REF=${PHARMCAT_UNSPECIFIED_TO_REF:-false}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      # First run downloads the GRCh38 reference (~8-15 min). Don't mark unhealthy before
      # then, or app's `depends_on: pharmcat: service_healthy` blocks the whole stack.
      start_period: 1200s
    networks:
      - pgx-network


  # HAPI FHIR Server for EHR/PHR/EMR integration
  # Pinned (not :latest) — this service owns a live Postgres schema shared with the
  # rest of the stack, and point releases have shipped non-zero-downtime migrations.
  # Bump ${HAPI_FHIR_TAG} deliberately; update data/versions/hapi.json to match.
  fhir-server:
    image: hapiproject/hapi:${HAPI_FHIR_TAG:-v8.10.0-2}
    container_name: pgx_fhir_server
    restart: unless-stopped
    ports:
      - "8090:8080"
    environment:
      - hapi.fhir.allow_external_references=true
      - hapi.fhir.allow_multiple_delete=true
      - hapi.fhir.reuse_cached_search_results_millis=60000
      - spring.datasource.url=jdbc:postgresql://db:5432/${DB_NAME:-zaropgx_db}?currentSchema=fhir
      - spring.datasource.username=${DB_USER:-zaropgx_user}
      - spring.datasource.password=${DB_PASSWORD:-test123}
      - spring.datasource.driverClassName=org.postgresql.Driver
      - spring.jpa.properties.hibernate.dialect=ca.uhn.fhir.jpa.model.dialect.HapiFhirPostgresDialect
      - spring.jpa.hibernate.ddl-auto=update
      - spring.jpa.properties.hibernate.default_schema=fhir
      - hapi.fhir.jpa.database_schema=update
      - hapi.fhir.jpa.auto_create_tables=true
      - hapi.fhir.jpa.database_schema_auto_create=true
      - hapi.fhir.jpa.database_schema_auto_validate=true
      - hapi.fhir.jpa.disable_temporary_table_creation=true
      - spring.jpa.open-in-view=false
      - hapi.fhir.max_page_size=50
      - hapi.fhir.default_page_size=20
      - hapi.fhir.subscription.resthook_enabled=true
      - hapi.fhir.subscription.websocket_enabled=false
      - JAVA_OPTS=-Djava.io.tmpdir=/tmp -Xmx2g
      - SPRING_DATASOURCE_INITIALIZATION_MODE=always
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - ./data/fhir-data:/data/hapi
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/fhir/metadata"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    networks:
      - pgx-network


  # GATK Service Wrapper
  gatk-api:
    image: zaromicsresearch/zaropgx-gatk-api:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: docker/gatk-api/Dockerfile.gatk-api
    container_name: pgx_gatk_api
    restart: unless-stopped
    depends_on:
      genome-downloader:
        condition: service_healthy
    volumes:
      - ./data:/data
      - ./reference:/reference
    environment:
      - REFERENCE_DIR=/reference
      - DATA_DIR=/data
      - MAX_MEMORY=20g
      - PYTHONPATH=/app
      - UVICORN_RELOAD_EXCLUDES=".git/*,.venv/*"
    ports:
      - "5002:5000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 40s
    networks:
      - pgx-network
    deploy:
      resources:
        limits:
          memory: 28G


  # PyPGx Service Wrapper
  pypgx:
    image: zaromicsresearch/zaropgx-pypgx:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: docker/pypgx/Dockerfile.pypgx
    container_name: pgx_pypgx
    restart: unless-stopped
    depends_on:
      genome-downloader:
        condition: service_healthy
    volumes:
      - ./data:/data
      - ./reference:/reference
      - ./config:/app/config
    environment:
      - DATA_DIR=/data
      - REFERENCE_DIR=/reference
      - PYPGX_MEMORY_LIMIT=7G
      - PYPGX_MAX_PARALLEL_GENES=8
      - PYPGX_BATCH_SIZE=4
      - PYPGX_PHARMCAT_PREFERENCE=pharmcat  # auto|pypgx|pharmcat
    ports:
      - "5053:5000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 40s
    networks:
      - pgx-network
    deploy:
      resources:
        limits:
          memory: 20G
        reservations:
          memory: 7G


  # ZaroHLA — OptiType v1.5 HLA Class I typing service.
  # ACTIVE HLA path: the app, the Nextflow pipeline, and the workflow router all
  # call it at http://zarohla:5000 (gated on OPTITYPE_ENABLED).
  zarohla:
    image: zaromicsresearch/zaropgx-zarohla:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: docker/zarohla/Dockerfile
    container_name: pgx_zarohla
    restart: unless-stopped
    environment:
      - DATA_DIR=/data
      - WORKFLOW_API_BASE=http://app:8000/api/v1
    volumes:
      - ./data:/data
    ports:
      - "5060:5000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    networks:
      - pgx-network

  # nf-core/hlatyping Wrapper Service (HTTP API running Nextflow) — DISABLED
  # The docker/hlatyping/ build context is missing, so this service cannot build.
  # Kept as a restorable placeholder (alternate HLA path, now with HLA-HD support).
  # To re-enable: restore docker/hlatyping/Dockerfile.hlatyping for nf-core/hlatyping
  # pipeline v2.2.0 (requires Nextflow >= 25.04.2), then uncomment the block below.
  # hlatyping:
  #   build:
  #     context: .
  #     dockerfile: docker/hlatyping/Dockerfile.hlatyping
  #   container_name: pgx_hlatyping
  #   restart: unless-stopped
  #   environment:
  #     - DATA_DIR=/data
  #     - HLATYPING_PROFILE=docker
  #     - HLATYPING_PIPELINE_VERSION=2.2.0
  #     - NXF_OPTS=-Xms1g -Xmx8g
  #   volumes:
  #     - ./data:/data
  #     # Mount host docker socket so Nextflow can launch docker tasks with -profile docker
  #     - /var/run/docker.sock:/var/run/docker.sock
  #     - ./data/nextflow:/opt/nextflow
  #   ports:
  #     - "5061:5000"
  #   healthcheck:
  #     test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
  #     interval: 30s
  #     timeout: 10s
  #     retries: 5
  #     start_period: 40s
  #   networks:
  #     - pgx-network


  # Kroki Service for diagram and visual rendering
  kroki:
    image: yuzutech/kroki:latest
    container_name: pgx_kroki
    restart: unless-stopped
    depends_on:
      - mermaid
    ports:
      - "8001:8000"
    environment:
      - KROKI_SAFE_MODE=false
      - KROKI_MAX_DURATION=30000
      - KROKI_MAX_SIZE=10485760
      - KROKI_LOG_LEVEL=INFO
      - KROKI_MERMAID_HOST=mermaid
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - pgx-network


  mermaid:
    image: yuzutech/kroki-mermaid:latest
    container_name: pgx_kroki_mermaid
    restart: unless-stopped
    command: ["--no-sandbox", "--disable-dev-shm-usage", "--disable-software-rasterizer", "--disable-gpu", "--disable-features=GlobalMediaControls"]
    expose:
      - "8002"
    environment:
      - CHROME_ARGS=--disable-dbus --no-sandbox --disable-dev-shm-usage --disable-gpu
    networks:
      - pgx-network


  # Nextflow executor orchestrating the ZaroPGx pipeline
  nextflow:
    # CORE pipeline orchestrator — the app submits every analysis here (USE_NEXTFLOW=True).
    image: zaromicsresearch/zaropgx-nextflow:${ZAROPGX_TAG:-0.2.7}
    build:
      context: .
      dockerfile: docker/nextflow/Dockerfile.nextflow
    container_name: pgx_nextflow
    restart: unless-stopped
    environment:
      - NXF_HOME=/opt/nextflow
      - NXF_OPTS=-Xms1g -Xmx4g
    volumes:
      - ./:/workspace
      - ./data:/data
      - ./reference:/reference
      - ./data/nextflow:/opt/nextflow
      # Allow Nextflow to launch docker tasks when using -profile docker
      - /var/run/docker.sock:/var/run/docker.sock
    working_dir: /workspace
    ports:
      - "5055:5055"
    networks:
      - pgx-network


  # Sphinx Documentation service (live reload)
  docs:
    # Optional and build-only (the app also serves docs at /documentation).
    # Opt in with: docker compose --profile optional up -d
    profiles: ["optional"]
    build:
      context: .
      dockerfile: docker/docs/Dockerfile.docs
    container_name: pgx_docs
    restart: unless-stopped
    volumes:
      - ./docs:/docs
    ports:
      - "5070:8000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - pgx-network


volumes:
  pgdata:
    driver: local
  # Note: fhir-data volume defined but fhir-server uses bind mount ./data/fhir-data
  # Consider using this named volume for production deployments
  fhir-data:
    driver: local
  pharmcat-references:
    driver: local


networks:
  pgx-network:
    name: pgx-network
    driver: bridge
    ipam:
      driver: default
      config:
        - subnet: ${NETWORK_SUBNET:-172.28.0.0/16}